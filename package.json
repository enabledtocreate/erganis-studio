{
  "name": "erganis-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Erganis Studio — designer web and desktop apps",
  "workspaces": [
    "apps/*",
    "shared"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @erganis/studio-web",
    "dev:desktop": "npm run dev -w @erganis/studio-desktop",
    "build:web": "npm run build -w @erganis/studio-web",
    "build:desktop": "npm run build -w @erganis/studio-desktop",
    "package:desktop": "npm run package -w @erganis/studio-desktop",
    "package:desktop:mac": "npm run package:mac -w @erganis/studio-desktop",
    "package:desktop:win": "npm run package:win -w @erganis/studio-desktop",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
